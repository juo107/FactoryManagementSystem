## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if using tasks.vs.json
#tasks.vs.json

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# [VB.NET] build results
*.pdb
*.xml

# [F#] build results
*.fsx.res
*.fsx.resx

# [C++] build results
*.aps
*.idb
*.intermediate.manifest
*.lib
*.ncb
*.obj
*.pch
*.pres.xml
*.res
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
*.vcxproj.user
*.vcproj.user
*.ndb
*.i32
*.db
*.ipch
*.sdf
*.opensdf
*.opendb
*.VC.db

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Code project settings
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Micro-Framework Properties
*.infoprops

# TeamCity is a build add-on
_TeamCity*

# DotCover is a Code Coverage Tool
*.dotCover

# AxoCover is a Code Coverage Tool
.axoCover/*
!.axoCover/settings.json

# Coverlet is a Code Coverage Tool
coverage/
*.cobertura.xml

# Visual Studio code coverage settings
*.runsettings

# ReSharper is a dotNet coding add-on
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode is a dotNet coding add-on
.JustCode

# Team Foundation error msgs
*.ssms.lock
*.sstest.lock

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator add-on
DocProject/buildhelp/
DocProject/Help/*.mcgh

# NDepend is a code analysis add-on
NDependOut/

# Visual Studio Archive Settings
artifacts/

# SQLite database files
*.db
*.db-shm
*.db-wal

# Log files
*.log

# Windows image caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on separate drives
$RECYCLE.BIN/

# Visual Studio Open Folder project-specific files
.vs/
.online/

# Rider Settings
.idea/

# Dotsettings
*.DotSettings.user

# Local appsettings
appsettings.Development.json
appsettings.Local.json
